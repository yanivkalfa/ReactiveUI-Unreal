{
  "name": "uetkx",
  "displayName": "UETKX (Unreal - VS Code)",
  "description": "Syntax highlighting + language intelligence for .uetkx markup (ReactiveUI for Unreal) — completions, hover, diagnostics, formatting from the compiler schema. Fully offline. Discord: discord.gg/Knedqu4Wyv | github.com/yanivkalfa/ReactiveUI-Unreal",
  "version": "0.6.0",
  "publisher": "ReactiveUITK",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/yanivkalfa/ReactiveUI-Unreal"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "unreal",
    "slate",
    "reactiveui",
    "uetkx",
    "jsx"
  ],
  "activationEvents": [
    "onLanguage:uetkx"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "uetkx.restartLanguageServer",
        "title": "Restart Language Server",
        "category": "UETKX"
      }
    ],
    "configuration": {
      "title": "UETKX",
      "properties": {
        "uetkx.clangd.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to a `clangd` executable for embedded-C++ intelligence inside `.uetkx` setup/hook/module bodies. Leave empty to auto-discover (PATH → `%LOCALAPPDATA%\\uetkx\\clangd\\bin` → `C:\\Program Files\\LLVM` → the VS 2022 Clang tools component). Requires a restart of the language server."
        }
      }
    },
    "languages": [
      {
        "id": "uetkx",
        "aliases": [
          "UETKX",
          "uetkx"
        ],
        "extensions": [
          ".uetkx"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "configurationDefaults": {
      "[uetkx]": {
        "editor.defaultFormatter": "ReactiveUITK.uetkx",
        "editor.formatOnSave": true,
        "editor.autoIndent": "full",
        "editor.insertSpaces": false,
        "editor.detectIndentation": false,
        "editor.bracketPairColorization.enabled": false
      },
      "files.exclude": {
        "**/*.uetkx.inl": true,
        "**/*.uetkx.diags.json": true,
        "**/*.Uetkx.gen.cpp": true
      }
    },
    "grammars": [
      {
        "language": "uetkx",
        "scopeName": "source.uetkx",
        "path": "./syntaxes/uetkx.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.cpp": "cpp"
        }
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./ && node scripts/bundle-server.mjs",
    "watch": "tsc -w -p ./",
    "package": "npm run build && npx @vscode/vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "typescript": "^5.4.0"
  }
}

{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "UETKX",
  "scopeName": "source.uetkx",
  "fileTypes": ["uetkx"],
  "comment": "Ported from the Unity sibling's uitkx grammar architecture: NO source.cpp embed — a hand-rolled C++ mini-tokenizer (#expression-content) with distinct scopes, markup↔code mutual recursion (#code-block-body), and anti-runaway guards ((?<==)\\{ attr lookbehind, strings-first ordering, (?<![=!<])> tag end). Divergence from the sibling: element vs component tags split STATICALLY (our host vocabulary is closed — 15 names, pinned by the schema test) and Use-hooks get their own scope (our hooks are PascalCase, the sibling's are camelCase).",
  "patterns": [
    { "include": "#markup-comment" },
    { "include": "#preprocessor" },
    { "include": "#import-namespace-decl" },
    { "include": "#import-decl" },
    { "include": "#import-host-include" },
    { "include": "#import-default-decl" },
    { "include": "#export-default-stmt" },
    { "include": "#export-list-stmt" },
    { "include": "#export-keyword" },
    { "include": "#component-decl" },
    { "include": "#hook-decl" },
    { "include": "#module-decl" },
    { "include": "#new-component-decl" },
    { "include": "#control-flow-with-expression" },
    { "include": "#control-flow-keyword" },
    { "include": "#tag-element" },
    { "include": "#tag-close" },
    { "include": "#code-block-body" }
  ],
  "repository": {
    "markup-comment": {
      "patterns": [
        { "name": "comment.block.html.uetkx", "begin": "<!--", "end": "-->" }
      ]
    },
    "preprocessor": {
      "name": "meta.preprocessor.uetkx",
      "match": "^\\s*#\\s*(include|pragma|define|if|ifdef|ifndef|endif|else)\\b.*$",
      "captures": { "1": { "name": "keyword.control.directive.uetkx" } }
    },
    "import-decl": {
      "comment": "Imported names color as WHAT THEY ARE at the use site (sibling behavior): Use-hooks get the hook-call scope, everything else the component-tag scope (modules read as types — same color). ES-modules (G-05): the `as` rename keyword colors as a keyword; both sides of a rename keep their kind scopes.",
      "match": "\\b(import)\\s*(\\{)([^}]*)(\\})\\s*(from)\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.uetkx" },
        "2": { "name": "punctuation.definition.block.begin.uetkx" },
        "3": {
          "patterns": [
            { "match": "\\b(as)\\b", "name": "keyword.control.import.uetkx" },
            { "match": "\\b(Use[A-Z][A-Za-z0-9_]*|ProvideContext)\\b", "name": "support.function.hook.uetkx" },
            { "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b", "name": "support.class.component.uetkx" }
          ]
        },
        "4": { "name": "punctuation.definition.block.end.uetkx" },
        "5": { "name": "keyword.control.import.uetkx" },
        "6": { "name": "string.quoted.double.uetkx" }
      }
    },
    "import-namespace-decl": {
      "comment": "ES-modules (G-05): `import * as X from \"./x\"` — the namespace alias reads as a type (a `X::Member` qual looks like a C++ namespace at use sites).",
      "match": "\\b(import)\\s*(\\*)\\s*(as)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s+(from)\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.uetkx" },
        "2": { "name": "keyword.operator.uetkx" },
        "3": { "name": "keyword.control.import.uetkx" },
        "4": { "name": "entity.name.type.module.uetkx" },
        "5": { "name": "keyword.control.import.uetkx" },
        "6": { "name": "string.quoted.double.uetkx" }
      }
    },
    "import-default-decl": {
      "comment": "ES-modules (G-05): `import X from \"./x\"` — a default import binds the target's `export default` symbol (usually a component) — plus the ES COMBINED forms `import X, { a as b } from` and `import X, * as NS from` (one declaration carrying the default binding and the named/star surface). Listed AFTER import-decl/import-host-include so the braced/quoted heads win.",
      "match": "\\b(import)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?:,\\s*(?:(\\{)([^}]*)(\\})|(\\*)\\s*(as)\\s+([A-Za-z_][A-Za-z0-9_]*)))?\\s+(from)\\s*(\"[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.uetkx" },
        "2": { "name": "support.class.component.uetkx" },
        "3": { "name": "punctuation.definition.block.begin.uetkx" },
        "4": {
          "patterns": [
            { "match": "\\b(as)\\b", "name": "keyword.control.import.uetkx" },
            { "match": "\\b(Use[A-Z][A-Za-z0-9_]*|ProvideContext)\\b", "name": "support.function.hook.uetkx" },
            { "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b", "name": "support.class.component.uetkx" }
          ]
        },
        "5": { "name": "punctuation.definition.block.end.uetkx" },
        "6": { "name": "keyword.operator.uetkx" },
        "7": { "name": "keyword.control.import.uetkx" },
        "8": { "name": "entity.name.type.module.uetkx" },
        "9": { "name": "keyword.control.import.uetkx" },
        "10": { "name": "string.quoted.double.uetkx" }
      }
    },
    "import-host-include": {
      "comment": "`import \"@Header.h\"` (INCLUDE_RETIREMENT_PLAN.md §B) — a nameless host include; same scopes as import-decl so it colors identically to a file import.",
      "match": "\\b(import)\\b\\s*(\"@[^\"]*\")",
      "captures": {
        "1": { "name": "keyword.control.import.uetkx" },
        "2": { "name": "string.quoted.double.uetkx" }
      }
    },
    "export-default-stmt": {
      "comment": "ES-modules (U-08): `export default Name;` — a statement, one per file.",
      "match": "\\b(export)\\s+(default)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.control.export.uetkx" },
        "2": { "name": "keyword.control.export.uetkx" },
        "3": { "name": "support.class.component.uetkx" }
      }
    },
    "export-list-stmt": {
      "comment": "ES-modules (U-09): `export { a, b };` — a deferred export list.",
      "match": "\\b(export)\\s*(\\{)([^}]*)(\\})",
      "captures": {
        "1": { "name": "keyword.control.export.uetkx" },
        "2": { "name": "punctuation.definition.block.begin.uetkx" },
        "3": {
          "patterns": [
            { "match": "\\b(Use[A-Z][A-Za-z0-9_]*|ProvideContext)\\b", "name": "support.function.hook.uetkx" },
            { "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b", "name": "support.class.component.uetkx" }
          ]
        },
        "4": { "name": "punctuation.definition.block.end.uetkx" }
      }
    },
    "export-keyword": {
      "comment": "ES-modules (G-10): `export` now also precedes plain typed declarations — the lookahead widened from the wrapper-keyword list to any identifier head.",
      "match": "\\b(export)\\s+(?=[A-Za-z_])",
      "captures": { "1": { "name": "keyword.control.export.uetkx" } }
    },
    "new-component-decl": {
      "comment": "ES-modules (U-01): the new plain component head `FRuiNode Name(...)` — the name gets the same component scope the wrapper form gave it.",
      "match": "\\b(FRuiNode)\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.type.uetkx" },
        "2": { "name": "entity.name.type.component.uetkx" }
      }
    },
    "component-decl": {
      "match": "\\b(component)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.directive.uetkx" },
        "2": { "name": "entity.name.type.component.uetkx" }
      }
    },
    "hook-decl": {
      "match": "\\b(hook)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.hook.uetkx" },
        "2": { "name": "entity.name.function.hook.uetkx" }
      }
    },
    "module-decl": {
      "match": "\\b(module)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.other.module.uetkx" },
        "2": { "name": "entity.name.type.module.uetkx" }
      }
    },
    "control-flow-with-expression": {
      "name": "meta.control.uetkx",
      "begin": "(@)(if|elif|for|while|match)\\b\\s*(\\()",
      "end": "(\\))",
      "beginCaptures": {
        "1": { "name": "keyword.control.directive.uetkx" },
        "2": { "name": "keyword.control.directive.uetkx" },
        "3": { "name": "punctuation.section.group.begin.uetkx" }
      },
      "endCaptures": { "1": { "name": "punctuation.section.group.end.uetkx" } },
      "patterns": [{ "include": "#expression-content" }]
    },
    "control-flow-keyword": {
      "match": "(@)(if|elif|else|for|while|match|case|default)\\b",
      "captures": {
        "1": { "name": "keyword.control.directive.uetkx" },
        "2": { "name": "keyword.control.directive.uetkx" }
      }
    },
    "tag-element": {
      "comment": "One region per ELEMENT — `<Name attrs>` through `</Name>` (or `/>`), the TSX jsx-element shape, so raw-text children get a home (TB-3). The begin is triple-guarded against C++ (TB-1b): no identifier/)/] immediately before `<` (kills `UseMemo<T>` generics), tag name REQUIRED (kills bare `i < 3`), and the name must be followed by tag-ish continuation — attr, `>`, `/>`, or end-of-line (kills `A < B` comparisons).",
      "name": "meta.tag.element.uetkx",
      "begin": "(?<![A-Za-z0-9_)\\]])(<)(?!/)((?:Border|Box|Button|CheckBox|EditableTextBox|HorizontalBox|Image|Overlay|ProgressBar|RuiCanvas|ScrollBox|Slider|Spacer|TextBlock|VerticalBox)\\b|[A-Za-z_][A-Za-z0-9_]*)(?=\\s*/?>|\\s+[A-Za-z_{]|\\s*$)",
      "end": "(/>)|(</)\\s*((?:Border|Box|Button|CheckBox|EditableTextBox|HorizontalBox|Image|Overlay|ProgressBar|RuiCanvas|ScrollBox|Slider|Spacer|TextBlock|VerticalBox)\\b|[A-Za-z_][A-Za-z0-9_]*)?\\s*(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.uetkx" },
        "2": {
          "patterns": [
            {
              "match": "\\b(Border|Box|Button|CheckBox|EditableTextBox|HorizontalBox|Image|Overlay|ProgressBar|RuiCanvas|ScrollBox|Slider|Spacer|TextBlock|VerticalBox)\\b",
              "name": "entity.name.type.element.uetkx"
            },
            { "match": "[A-Za-z_][A-Za-z0-9_]*", "name": "support.class.component.uetkx" }
          ]
        }
      },
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.end.uetkx" },
        "2": { "name": "punctuation.definition.tag.begin.uetkx" },
        "3": {
          "patterns": [
            {
              "match": "\\b(Border|Box|Button|CheckBox|EditableTextBox|HorizontalBox|Image|Overlay|ProgressBar|RuiCanvas|ScrollBox|Slider|Spacer|TextBlock|VerticalBox)\\b",
              "name": "entity.name.type.element.uetkx"
            },
            { "match": "[A-Za-z_][A-Za-z0-9_]*", "name": "support.class.component.uetkx" }
          ]
        },
        "4": { "name": "punctuation.definition.tag.end.uetkx" }
      },
      "patterns": [
        {
          "comment": "Attributes — anchored at the spot right after `<Name`, ends when the OPEN tag closes (`>` not part of =>/!>/->/`<`) or defers to the outer end for `/>`.",
          "begin": "\\G",
          "end": "(?=/>)|((?<![=!<-])>)",
          "endCaptures": { "1": { "name": "punctuation.definition.tag.end.uetkx" } },
          "patterns": [{ "include": "#tag-attributes" }]
        },
        { "include": "#markup-comment" },
        { "include": "#control-flow-with-expression" },
        { "include": "#control-flow-keyword" },
        { "include": "#tag-element" },
        { "include": "#markup-brace" },
        {
          "comment": "Raw-text children (`+`, `Back home`, `Shuffle(bump RedrawKey)`) — meta scope only, so the theme's DEFAULT foreground applies (TB-3).",
          "match": "[^<{@]+",
          "name": "meta.text.children.uetkx"
        }
      ]
    },
    "tag-close": {
      "comment": "Orphan close tags only (a healthy close is consumed by its tag-element's end).",
      "match": "(</)([A-Za-z_][A-Za-z0-9_]*)?\\s*(>)",
      "captures": {
        "1": { "name": "punctuation.definition.tag.begin.uetkx" },
        "2": {
          "patterns": [
            {
              "match": "\\b(Border|Box|Button|CheckBox|EditableTextBox|HorizontalBox|Image|Overlay|ProgressBar|RuiCanvas|ScrollBox|Slider|Spacer|TextBlock|VerticalBox)\\b",
              "name": "entity.name.type.element.uetkx"
            },
            { "match": "[A-Za-z_][A-Za-z0-9_]*", "name": "support.class.component.uetkx" }
          ]
        },
        "3": { "name": "punctuation.definition.tag.end.uetkx" }
      }
    },
    "tag-attributes": {
      "patterns": [
        { "name": "comment.block.attr.uetkx", "begin": "\\{\\s*/\\*", "end": "\\*/\\s*\\}" },
        { "include": "#attribute-value-expression" },
        { "include": "#double-quoted-string" },
        {
          "match": "\\b(key|classes)(?=\\s*[={])",
          "name": "entity.other.attribute-name.structural.uetkx"
        },
        {
          "match": "\\b(On[A-Z][A-Za-z0-9_]*)(?=\\s*[={])",
          "name": "entity.other.attribute-name.event.uetkx"
        },
        {
          "match": "\\b(Slot\\.[A-Za-z_][A-Za-z0-9_.]*)(?=\\s*[={])",
          "name": "entity.other.attribute-name.slot.uetkx"
        },
        {
          "match": "[A-Za-z_][A-Za-z0-9_.\\-]*",
          "name": "entity.other.attribute-name.uetkx"
        }
      ]
    },
    "attribute-value-expression": {
      "comment": "Only a { immediately preceded by = is an attribute expression — the lookbehind keeps control-flow braces out (sibling anti-runaway guard).",
      "begin": "(?<==)\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.uetkx" } },
      "endCaptures": { "0": { "name": "punctuation.section.embedded.end.uetkx" } },
      "patterns": [{ "include": "#expression-content" }]
    },
    "markup-brace": {
      "comment": "A { ... } inside markup/code — full markup+code recursion so nesting depth never loses coloring.",
      "begin": "\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.embedded.begin.uetkx" } },
      "endCaptures": { "0": { "name": "punctuation.section.embedded.end.uetkx" } },
      "patterns": [{ "include": "#code-block-body" }]
    },
    "code-block-body": {
      "comment": "Content of component/hook/module bodies and directive bodies — expression tokenization PLUS embedded markup (the mutual recursion that keeps both regions distinct).",
      "patterns": [
        { "include": "#cpp-line-comment" },
        { "include": "#cpp-block-comment" },
        { "include": "#control-flow-with-expression" },
        { "include": "#control-flow-keyword" },
        { "include": "#markup-comment" },
        { "include": "#tag-element" },
        { "include": "#tag-close" },
        { "include": "#markup-brace" },
        { "include": "#expression-content" }
      ]
    },
    "expression-content": {
      "comment": "The hand-rolled C++ tokenizer — ordered: comments/strings first, then hooks, keywords, types, numbers, operators, recursion, calls, identifiers.",
      "patterns": [
        { "include": "#cpp-line-comment" },
        { "include": "#cpp-block-comment" },
        { "include": "#double-quoted-string" },
        { "include": "#char-literal" },
        { "include": "#hook-call" },
        { "include": "#cpp-keywords" },
        { "include": "#cpp-type-name" },
        { "include": "#function-call" },
        { "include": "#numeric-literal" },
        { "include": "#cpp-operator" },
        { "include": "#markup-brace" },
        { "include": "#paren-expression" },
        { "include": "#identifier" }
      ]
    },
    "cpp-line-comment": { "name": "comment.line.double-slash.uetkx", "match": "//.*$" },
    "cpp-block-comment": { "name": "comment.block.uetkx", "begin": "/\\*", "end": "\\*/" },
    "double-quoted-string": {
      "comment": "Dedicated rule so a } inside a string can never close an embedded block early.",
      "name": "string.quoted.double.uetkx",
      "begin": "\"",
      "end": "\"",
      "patterns": [{ "name": "constant.character.escape.uetkx", "match": "\\\\." }]
    },
    "char-literal": {
      "name": "string.quoted.single.uetkx",
      "match": "'(\\\\.|[^'\\\\])'"
    },
    "hook-call": {
      "comment": "Use-hooks get a distinct scope (ours are PascalCase — a plain type rule would swallow them).",
      "match": "\\b(Use[A-Z][A-Za-z0-9_]*|ProvideContext)\\b",
      "name": "support.function.hook.uetkx"
    },
    "cpp-keywords": {
      "match": "\\b(auto|const|constexpr|static|inline|return|if|else|for|while|switch|case|break|continue|default|true|false|nullptr|new|delete|void|bool|char|int|struct|class|enum|namespace|using|template|typename|this|virtual|override|public|private|protected|int8|int16|int32|int64|uint8|uint16|uint32|uint64|float|double|TEXT|INVTEXT|NSLOCTEXT|MoveTemp|Forward)\\b",
      "name": "keyword.control.uetkx"
    },
    "cpp-type-name": {
      "comment": "Unreal-prefixed types ONLY (F/T/U/S/I/E + PascalCase: FLinearColor, TFunction, URuiHostWidget) plus ALL-CAPS names (RUI, macros). A bare PascalCase identifier is a LOCAL under Unreal naming — the old any-PascalCase rule painted every local green; locals must color as variables like the sibling's camelCase locals do.",
      "match": "\\b(?:[FTUSIE][A-Z][A-Za-z0-9_]*|[A-Z][A-Z0-9_]+)\\b",
      "name": "entity.name.type.uetkx"
    },
    "numeric-literal": {
      "match": "\\b[0-9]+(\\.[0-9]+)?f?\\b",
      "name": "constant.numeric.uetkx"
    },
    "cpp-operator": {
      "match": "->|::|\\+\\+|--|&&|\\|\\||[+\\-*/%!<>=&|^~?:]",
      "name": "keyword.operator.uetkx"
    },
    "paren-expression": {
      "begin": "\\(",
      "end": "\\)",
      "beginCaptures": { "0": { "name": "punctuation.section.group.begin.uetkx" } },
      "endCaptures": { "0": { "name": "punctuation.section.group.end.uetkx" } },
      "patterns": [{ "include": "#code-block-body" }]
    },
    "function-call": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*(?=\\s*\\()",
      "name": "entity.name.function.uetkx"
    },
    "identifier": {
      "comment": "Any-case start: Unreal locals are PascalCase (Count, SetCount), not just camelCase.",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.uetkx"
    }
  }
}

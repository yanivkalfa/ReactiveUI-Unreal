{
  "name": "uetkx-language-server",
  "version": "0.3.0",
  "description": "Language server for .uetkx (ReactiveUI for Unreal markup): markup intelligence from the compiler-exported schema + diagnostics sidecars; embedded-C++ intelligence degrades gracefully without clangd.",
  "license": "MIT",
  "main": "out/server.js",
  "bin": {
    "uetkx-language-server": "out/server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p ./ && node scripts/copy-assets.mjs",
    "watch": "tsc -w -p ./",
    "test": "tsc -p ./ && node scripts/copy-assets.mjs && node --test out/test/*.test.js"
  },
  "dependencies": {
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}

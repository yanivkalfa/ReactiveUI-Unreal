export component SimpleUseEffect {
	auto [Message, SetMessage] = UseState<FString>(FString(TEXT("Waiting...")));
	TFunction<void(FString)> Set = SetMessage;
	UseEffect([Set]() { Set(FString(TEXT("Effect ran!"))); }, RUI::Deps());

	return (
		<Border Padding="12" BorderImage="WhiteBrush" BorderBackgroundColor={ FLinearColor(0.02f, 0.02f, 0.03f, 0.85f) } Slot.Padding="0,10,0,0">
			<TextBlock Text={ FText::FromString(FString::Printf(TEXT("Message: %s"), *Message)) } />
		</Border>
	);
}
